EBAY_BACKEND=scraperapi
SCRAPERAPI_KEY=your_scraperapi_key

EBAY_CLIENT_ID=your_ebay_client_id
EBAY_CLIENT_SECRET=your_ebay_client_secret
EBAY_ENV=production
EBAY_MARKETPLACE_ID=EBAY_US

TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHANNEL_ID=-1001234567890

GOOGLE_SHEETS_ID=your_google_sheet_id_from_url
GOOGLE_CREDENTIALS_PATH=./secrets/google-credentials.json

CONFIG_PATH=./config.yaml
POLL_INTERVAL_MINUTES=5
RULES_PER_RUN=8
RULE_SEARCH_DELAY_SECONDS=1
TELEGRAM_ALERT_DELAY_SECONDS=1.5
TELEGRAM_MAX_RETRIES=5
MAX_ALERTS_PER_RUN=20
DATA_DIR=./data
LOG_DIR=./logs
LOG_LEVEL=INFO
STATE_MAX_ENTRIES=10000
